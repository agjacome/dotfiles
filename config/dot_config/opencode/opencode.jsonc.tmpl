{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "ERROR",
  "username": "{{ .username }}",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5-fast",
  "default_agent": "build",
  "autoupdate": false,
  "share": "disabled",
  "disabled_providers": ["anthropic", "github-copilot", "gitlab"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.5-fast": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        },
      },
      "options": {
        "timeout": 300000
      }
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".direnv/**",
      "result/**",
      "dist/**",
      "build/**"
    ]
  },
  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "external_directory": "ask",
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  }
}
