[user]
    name  = Alberto G. Jácome
    email = {{ .gitEmail }}
    signingkey = {{ .gitSigningKey }}

[github]
    user = agjacome

[core]
    autocrlf     = input
    editor       = nvim
    excludesfile = ~/.config/git/ignore
    pager        = delta
    whitespace   = trailing-space,space-before-tab,indent-with-non-tab

[commit]
    gpgsign = true
[diff]
    algorithm = histogram
    noprefix = true
    tool = nvimdiff
[difftool]
    prompt = false
[fetch]
    prune = true
[help]
    autocorrect = 1
[init]
    defaultBranch = main
[interactive]
    diffFilter = delta --color-only
[merge]
    conflictstyle = zdiff3
    tool = nvimdiff
[pull]
    rebase = true
[push]
    autoSetupRemote = true
[rebase]
    autosquash = true
    autostash = true
    updateRefs = true
[rerere]
    enabled = true

[alias]
    amend  = commit --amend
    dst    = diff --staged
    gc     = !git reflog expire --expire-unreachable=now --all && git gc --aggressive --prune=now
    lg     = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ch) %C(bold blue)%Creset' --abbrev-commit

[delta]
    line-numbers = true
    navigate = true
    side-by-side = true
